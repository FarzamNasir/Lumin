# ── Environment ───────────────────────────────────────────
ENVIRONMENT=local  # "local" or "production"

# ── PostgreSQL ────────────────────────────────────────────
POSTGRES_USER=aggregator
POSTGRES_PASSWORD=aggregator_pass
POSTGRES_DB=news_aggregator

# Connection string used by the Python app
DATABASE_URL=postgresql://aggregator:aggregator_pass@127.0.0.1:5433/news_aggregator

# ── LLM Provider ─────────────────────────────────────────
# "groq" (default, free tier) or "openai"
LLM_PROVIDER=groq
GROQ_API_KEY=your-groq-api-key-here
# LLM_MODEL=llama-3.3-70b-versatile   # optional override

# OpenAI (only needed if LLM_PROVIDER=openai)
# OPENAI_API_KEY=your-openai-key-here

# ── Email (Gmail SMTP) ──────────────────────────────────
SMTP_EMAIL=your-gmail@gmail.com
SMTP_APP_PASSWORD=your-16-char-app-password
RECIPIENT_EMAIL=recipient@example.com  # fallback if no subscribers

# ── Web Service ──────────────────────────────────────────
BASE_URL=http://localhost:8000  # set to your Render URL in production
